# Server Configuration
PORT=3001

# Security - IMPORTANT: Change these in production!
JWT_SECRET=your_strong_secret_here_minimum_32_chars

# Environment
NODE_ENV=development

# Database Configuration
# MongoDB Connection String
# Format: mongodb+srv://username:password@host/database?options
MONGODB_URI=mongodb+srv://username:password@host/database?retryWrites=true&w=majority

# Database Mode: Set to true to use MongoDB, false to use in-memory database
USE_MONGODB=false

# CORS Configuration
# Comma-separated list of allowed origins (required in production)
# In development, set to '*' or specify frontend URL
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGIN=http://localhost:3000
