# Χρησιμοποιούμε την ελαφριά έκδοση του Node 18 (όπως ζητάει το package.json)
FROM node:18-alpine

# Φτιάχνουμε έναν φάκελο εργασίας μέσα στο Container
WORKDIR /app

# Αντιγράφουμε τα αρχεία των βιβλιοθηκών ΠΡΩΤΑ (για βελτιστοποίηση ταχύτητας)
COPY package*.json ./

# Εγκαθιστούμε τα πακέτα (Express, Mongoose, κτλ)
RUN npm install

# Αντιγράφουμε όλο τον υπόλοιπο κώδικά σου
COPY . .

# Ανοίγουμε την πόρτα 3001 προς τα έξω
EXPOSE 3001

# Η εντολή που θα τρέξει όταν ανάψει το Container
CMD ["npm", "start"]